# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database — Neon PostgreSQL
# Get your connection strings from https://console.neon.tech
# Use the pooled connection string for DATABASE_URL (for app queries)
# Use the direct connection string for DIRECT_DATABASE_URL (for migrations)
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.us-east-2.aws.neon.tech/dbname?sslmode=require"
DIRECT_DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require"

# Clerk Auth — https://clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Anthropic — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxx

# Stripe — https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Kid session JWT secret — generate with: openssl rand -hex 32
KID_SESSION_SECRET=your-random-32-byte-hex-secret-here
